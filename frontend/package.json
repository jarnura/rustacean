{
  "name": "@rustacean/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Rustacean control-plane web UI. Auth surfaces, tenant switcher, repos page.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:api": "openapi-typescript ../openapi.json -o src/api/generated/schema.ts --immutable",
    "gen:api:check": "node ./scripts/check-api-types.mjs",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-router": "^1.168.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "openapi-fetch": "^0.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.74.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.52.0",
    "@eslint/js": "^9.16.0",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.27",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=20"
  }
}
