      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0, "color": { "fixedColor": "orange", "mode": "fixed" } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(rb_sse_dropped_total[1m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "row",
