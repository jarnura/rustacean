{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "eslint.config.js",
    "scripts/**/*.mjs",
    "playwright.config.ts",
    "e2e/**/*.ts"
  ]
}
