      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Blob ops (ops/s)",
      "description": "rb_blob_op_total{op, store, outcome}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (op, store) (rate(rb_blob_op_total{outcome=\"ok\"}[1m]))",
